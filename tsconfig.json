{
    "compilerOptions": {
      "target": "ES2019",
      "module": "CommonJS",
      "moduleResolution": "node",
      "declaration": true,
      "declarationMap": true,
      "sourceMap": true,
      "strict": true,
      "esModuleInterop": true,
      "outDir": "dist",
      "rootDir": "src",
      "lib": ["ES2019", "DOM"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", "examples"]
  }
  